# PathWise AI — Environment Variables
# Copy this file to .env and fill in values for your environment.

# ── Database ────────────────────────────────────────────
POSTGRES_DB=pathwise
POSTGRES_USER=pathwise
POSTGRES_PASSWORD=pathwise_dev
DATABASE_URL=postgresql://pathwise:pathwise_dev@timescaledb:5432/pathwise

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── SDN Controller ──────────────────────────────────────
SDN_TYPE=opendaylight
ODL_URL=http://opendaylight:8181
ODL_USERNAME=admin
ODL_PASSWORD=admin

# ── Batfish ─────────────────────────────────────────────
BATFISH_HOST=batfish

# ── Prediction Engine ───────────────────────────────────
MODEL_PATH=/models/best_model.pt

# ── Frontend ────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── Debug ───────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
